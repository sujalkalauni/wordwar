# WordWar Application Properties Example
# Copy this file: cp application.properties.example application.properties
# Then fill in your actual values below

# ─── Application ───────────────────────────────────────────────
spring.application.name=wordwar
server.port=8083

# ─── Database ────────────────────────────────────────────────
spring.datasource.url=jdbc:mysql://localhost:3306/wordwar?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
spring.datasource.username=your_db_username
spring.datasource.password=your_db_password
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# Connection pool tuning
spring.datasource.hikari.maximum-pool-size=10
spring.datasource.hikari.minimum-idle=2
spring.datasource.hikari.connection-timeout=30000

# ─── JPA / Hibernate ─────────────────────────────────────────
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQL8Dialect

# ─── JWT ─────────────────────────────────────────────────────
# IMPORTANT: Change this secret in production! Use: openssl rand -base64 64
app.jwt.secret=wordwar-secret-key-change-in-production-minimum-256-bits
app.jwt.expiration=86400000

# ─── OpenAPI / Swagger ───────────────────────────────────────
springdoc.api-docs.path=/api-docs
springdoc.swagger-ui.path=/swagger-ui.html
springdoc.swagger-ui.enabled=true
springdoc.swagger-ui.operationsSorter=method

# ─── Logging ─────────────────────────────────────────────────
logging.level.com.wordwar=INFO
logging.level.org.springframework.security=WARN
logging.level.org.hibernate.SQL=WARN
